{
  "appId": "com.empire.dons",
  "appName": "D's Empire",
  "webDir": "build",
  "bundledWebRuntime": false,
  "backgroundColor": "#0f1419",
  "server": {
    "hostname": "empire.app",
    "androidScheme": "https"
  },
  "android": {
    "buildOptions": {
      "keystorePath": "release.keystore",
      "keystorePassword": "empire2025",
      "keystoreAlias": "empire",
      "keystoreAliasPassword": "empire2025",
      "releaseType": "APK"
    },
    "backgroundColor": "#0f1419",
    "allowMixedContent": true
  },
  "plugins": {
    "SplashScreen": {
      "launchShowDuration": 2000,
      "backgroundColor": "#0f1419",
      "androidScaleType": "CENTER_CROP",
      "showSpinner": false,
      "splashFullScreen": true,
      "splashImmersive": true
    }
  }
}
